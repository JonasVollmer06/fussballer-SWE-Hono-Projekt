# syntax=docker.io/docker/dockerfile-upstream:1.23.0
# check=error=true

# Aufruf:   docker build --tag juergenzimmermann/buch:2026.4.1-alpine -f Dockerfile.alpine .
#               ggf. --progress=plain
#               ggf. --no-cache
#
#           Windows:   Get-Content Dockerfile.alpine | docker run --rm --interactive hadolint/hadolint:v2.14.0-debian
#           macOS:     cat Dockerfile.alpine | docker run --rm --interactive hadolint/hadolint:v2.14.0-debian
#
#           docker debug juergenzimmermann/buch:2026.4.1-alpine
#           docker network ls
#           docker save juergenzimmermann/buch:2026.4.1-alpine > buch.tar

# https://docs.docker.com/engine/reference/builder/#syntax
# https://github.com/moby/buildkit/blob/master/frontend/dockerfile/docs/reference.md
# https://hub.docker.com/r/docker/dockerfile

ARG BUN_VERSION=1.3.13

FROM oven/bun:${BUN_VERSION}-alpine AS dist

WORKDIR /app

# https://docs.docker.com/engine/reference/builder/#run---mounttypebind
RUN --mount=type=bind,source=package.json,target=package.json \
  --mount=type=bind,source=bun.lock,target=bun.lock \
  --mount=type=cache,target=/root/.bun <<EOF
  bun install --frozen-lockfile --production
EOF

FROM oven/bun:${BUN_VERSION}-alpine AS final

WORKDIR /opt/app

RUN <<EOF
# https://explainshell.com/explain?cmd=set+-eux
set -eux

# apk = Alpine Package Keeper
# https://wiki.alpinelinux.org/wiki/Alpine_Package_Keeper
# https://docs.alpinelinux.org/user-handbook/0.1a/Working/apk.html
# Die "Package Index"-Dateien neu synchronisieren
apk update

# Die neuesten Versionen der bereits installierten Packages installieren
apk upgrade
apk cache clean
rm -rf /tmp/*
EOF

USER bun

COPY --chown=bun:bun package.json ./
COPY --from=dist --chown=bun:bun /app/node_modules ./node_modules
COPY --chown=bun:bun src ./src

# Anzeige bei "docker inspect ..."
# https://specs.opencontainers.org/image-spec/annotations
# https://spdx.org/licenses
# MAINTAINER ist deprecated https://docs.docker.com/engine/reference/builder/#maintainer-deprecated
LABEL org.opencontainers.image.title="fussballer" \
  org.opencontainers.image.description="Appserver fussballer mit Basis-Image Alpine" \
  org.opencontainers.image.version="2026.4.1-alpine" \
  org.opencontainers.image.licenses="GPL-3.0-or-later" \
  org.opencontainers.image.authors="vojo1023@h-ka.de"

EXPOSE 3000
EXPOSE 3030

# Binding fuer alle Netzwerk-Interfaces
ENV BUN_BIND_HOST=0.0.0.0

# Bei CMD statt ENTRYPOINT kann das Kommando bei "docker run ..." ueberschrieben werden
# "Array Syntax" damit auch <Strg>C funktioniert
ENTRYPOINT ["bun", "run", "src/index.mts"]
